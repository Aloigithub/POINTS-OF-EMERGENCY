OutputDataCombined$TimeTaken<-ifelse(OutputDataCombined$Times=="POE",NA,OutputDataCombined$TimeTaken)
OutputDataCombined$WaitingTime<-ifelse(OutputDataCombined$Times=="POE",NA,OutputDataCombined$WaitingTime)
OutputDataCombined$OptimalTime<-ifelse(OutputDataCombined$Times=="POE",NA,OutputDataCombined$OptimalTime)
OutputDataCombined$Times<-ifelse(OutputDataCombined$Times=="POE","PEO",OutputDataCombined$Times)
# View(OutputDataCombined) #Select without hash tag to view data frame
OutputDataCombined

##### Optimal analysis
# tail(OutputDataCombined)

## Get the optimal time for each round
HarzardAnalysis<-OutputDataCombined %>%
  filter(Times=="Optimal") %>%
  select(Round,OptimalTime)
# View(HarzardAnalysis)

## Get the first time for each round, and merge to the optimal time in HarzardAnalysis
HarzardAnalysis<-merge(HarzardAnalysis,OutputDataCombined %>%
  filter(Times=="First") %>%
  mutate(FirstTime=OptimalTime) %>%
  select(Round,FirstTime),
  by.x = "Round", by.y = "Round")

## Get the second time for each round, and merge to the optimal and first time in HarzardAnalysis
HarzardAnalysis<-merge(HarzardAnalysis,OutputDataCombined %>%
                  filter(Times=="Second") %>%
                  mutate(SecondTime=OptimalTime) %>%
                  select(Round,SecondTime),
                by.x = "Round", by.y = "Round")


## Convert second time to zero if first time was optimal
HarzardAnalysis$SecondTime<-ifelse(HarzardAnalysis$OptimalTime==HarzardAnalysis$FirstTime,0,HarzardAnalysis$SecondTime)

## Calculates total time spent, and the difference in minutes spent (how many more minutes no optimal sill use to get service)
HarzardAnalysis<-HarzardAnalysis %>%
  mutate(Totals = FirstTime+SecondTime) %>%
  mutate(Risks = Totals<=OptimalTime) %>%
  mutate(Diffs = Totals-OptimalTime)

