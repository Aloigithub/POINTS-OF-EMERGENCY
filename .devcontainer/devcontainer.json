## Works with the remaining percentage where the Optimized AI Algorithm was a better option
### Gives a summary of extra minutes the person using the non optimized method would spend before being attended to
HarzardAnalysis %>%
  filter(Diffs>0) %>%
  summarise(MinDiff = min(Diffs),MaxDiff = max(Diffs), 
            AvgDiff = round(mean(Diffs),2),medDiff = round(median(Diffs),2))

