OutputDataCombined$F_NAME<-ifelse(OutputDataCombined$Times=="POE","",OutputDataCombined$F_NAME)
OutputDataCombined$Facility_Type<-ifelse(OutputDataCombined$Times=="POE","",OutputDataCombined$Facility_Type)
