                                       summarise(HarzardAnalysisPercentage = sum(Risks))*100/nrow(HarzardAnalysis),1),"% of the time",sep="")
paste("This means that ",100-round(HarzardAnalysis %>%
                                     summarise(HarzardAnalysisPercentage = sum(Risks))*100/nrow(HarzardAnalysis),1),
